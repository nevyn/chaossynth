# Copy to secrets.env (gitignored) and fill in. This file is sourced by
# bash: quote values that contain spaces. ASCII only; single quotes and
# backslashes are refused. WPA passwords must be 8-63 characters.
#
# Wifi: WIFI1..WIFI4 supported, higher number wins when several are
# visible -- keep the phone hotspot LAST so it takes over in the field.
WIFI_COUNTRY=SE
WIFI1_SSID=home-network
WIFI1_PSK=changeme
WIFI2_SSID=nevyns-phone-hotspot
WIFI2_PSK=changeme
CHAOS_USER=chaos
CHAOS_PASSWORD=changeme
SSH_PUBKEY_PATH=~/.ssh/id_ed25519.pub
